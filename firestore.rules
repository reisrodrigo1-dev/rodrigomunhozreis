rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ⚠️ Troque pelo seu e-mail de admin (o mesmo do login no /admin)
    function isAdmin() {
      return request.auth != null
        && request.auth.token.email == 'reis.mrodrigo@gmail.com';
    }

    // Captura pública de e-mail; leitura só admin
    match /leads/{id} {
      allow create: if request.resource.data.email is string
                    && request.resource.data.email.size() < 320;
      allow read, update, delete: if isAdmin();
    }

    // Registro público de downloads; leitura só admin
    match /downloads/{id} {
      allow create: if request.resource.data.email is string;
      allow read, update, delete: if isAdmin();
    }

    // Materiais (quando vierem do Firestore): leitura pública, escrita só admin
    match /materials/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Robôs (prompts): leitura pública, escrita só admin
    match /robots/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Alunos: cada um cria/lê/edita o próprio doc; admin lê todos
    match /students/{uid} {
      allow create: if request.auth != null && request.auth.uid == uid;
      allow read, update: if request.auth != null && (request.auth.uid == uid || isAdmin());
      allow delete: if isAdmin();
    }

    // Blog: posts publicados são públicos; rascunhos e escrita só admin
    match /posts/{id} {
      allow read: if resource.data.status == 'published' || isAdmin();
      allow write: if isAdmin();
    }
  }
}
